component App() {
    return (
        <div class="bg-gray-950 min-h-screen text-gray-200 font-sans selection:bg-indigo-500/30 overflow-x-hidden">
            <Header />
            
            <main class="relative z-10 pt-20">
                <div id="view-home" class="page-view block opacity-100 transition-opacity duration-500"><Home /></div>
                <div id="view-about" class="page-view hidden opacity-0 transition-opacity duration-500"><About /></div>
                <div id="view-services" class="page-view hidden opacity-0 transition-opacity duration-500"><Services /></div>
                <div id="view-contact" class="page-view hidden opacity-0 transition-opacity duration-500"><Contact /></div>
            </main>

            <Footer />
            
            @client {
                // SPA Router Logic
                function navigate(page) {
                    let home = document.getElementById("view-home");
                    let about = document.getElementById("view-about");
                    let services = document.getElementById("view-services");
                    let contact = document.getElementById("view-contact");
                    
                    if (home) { home.className = "page-view hidden"; }
                    if (about) { about.className = "page-view hidden"; }
                    if (services) { services.className = "page-view hidden"; }
                    if (contact) { contact.className = "page-view hidden"; }
                    
                    let target = document.getElementById("view-" + page);
                    if(target) {
                        target.className = "page-view block opacity-100 transition-opacity duration-300";
                    }
                    
                    window.scrollTo({ top: 0, behavior: "smooth" });
                }
            }
        </div>
    );
}

<?php
$Router->get("/api/health", fn() => ["status" => "online", "version" => "1.0", "message" => "NexCore is solid."]);
?>

@client {
    <App />
}
