component Contact() {
    return (
        <div class="min-h-screen pt-40 pb-20 px-6 max-w-5xl mx-auto flex flex-col justify-center relative">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-blue-600/10 to-indigo-600/10 rounded-full blur-[120px] pointer-events-none"></div>
            
            <div class="relative z-10 bg-gray-900 border border-white/10 p-12 md:p-20 rounded-[3rem] shadow-2xl">
                <div class="grid md:grid-cols-2 gap-16 items-start">
                    <div>
                        <div class="inline-flex items-center gap-2 mb-6">
                            <div class="w-10 h-1 bg-indigo-500 rounded-full"></div>
                            <span class="text-indigo-400 font-bold tracking-widest uppercase">Merhaba Deyin</span>
                        </div>
                        <h2 class="text-4xl md:text-5xl font-black text-white mb-6">Projeyi Birlikte Yaratalım</h2>
                        <p class="text-gray-400 text-lg mb-10">Kahvenizi alın, bize hedeflerinizi anlatın. Ekibimiz sizin için en doğru dijital rotayı ücretsiz çıkarsın.</p>
                        
                        <div class="space-y-6">
                            <div class="flex items-center gap-4 text-gray-300">
                                <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-white border border-white/10">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                </div>
                                <span class="font-medium text-lg">hello@nexcore.dev</span>
                            </div>
                            <div class="flex items-center gap-4 text-gray-300">
                                <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-white border border-white/10">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                </div>
                                <span class="font-medium text-lg">+90 (850) 123 45 67</span>
                            </div>
                        </div>
                    </div>
                
                    <form id="contactForm" class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-400 uppercase tracking-wider">Adınız Soyadınız</label>
                            <input type="text" id="name" class="w-full bg-black/40 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all placeholder-gray-600" placeholder="John Doe" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-400 uppercase tracking-wider">E-posta</label>
                            <input type="email" id="email" class="w-full bg-black/40 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all placeholder-gray-600" placeholder="john@example.com" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-400 uppercase tracking-wider">Mesajınız</label>
                            <textarea id="message" rows="4" class="w-full bg-black/40 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all placeholder-gray-600 resize-none" placeholder="Harika fikrinizden bahsedin..."></textarea>
                        </div>
                        
                        <button type="button" onclick="handleSend()" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-black text-lg py-5 rounded-2xl hover:shadow-[0_0_30px_rgba(79,70,229,0.5)] transition-all duration-300">
                            Hemen Gönder
                        </button>
                        
                        <div id="statusAlert" class="hidden p-4 rounded-xl border font-bold text-center transition-all bg-opacity-10 backdrop-blur-sm"></div>
                    </form>
                </div>
            </div>
            
            @client {
                function handleSend() {
                    let n = document.getElementById("name").value.trim();
                    let e = document.getElementById("email").value.trim();
                    let m = document.getElementById("message").value.trim();
                    let alertBox = document.getElementById("statusAlert");
                    
                    if(n === "") {
                        alertBox.className = "mt-4 p-4 rounded-xl border font-bold text-center transition-all bg-red-500/10 border-red-500/50 text-red-400 block";
                        alertBox.innerText = "Lütfen tüm adımları eksiksiz doldurun.";
                        return;
                    }
                    if(e === "") {
                        alertBox.className = "mt-4 p-4 rounded-xl border font-bold text-center transition-all bg-red-500/10 border-red-500/50 text-red-400 block";
                        alertBox.innerText = "Lütfen tüm adımları eksiksiz doldurun.";
                        return;
                    }
                    if(m === "") {
                        alertBox.className = "mt-4 p-4 rounded-xl border font-bold text-center transition-all bg-red-500/10 border-red-500/50 text-red-400 block";
                        alertBox.innerText = "Lütfen tüm adımları eksiksiz doldurun.";
                        return;
                    }
                    
                    // Simulate processing
                    alertBox.className = "mt-4 p-4 rounded-xl border font-bold text-center transition-all bg-indigo-500/10 border-indigo-500/50 text-indigo-400 block";
                    alertBox.innerText = "Yükleniyor...";
                    
                    setTimeout(() => {
                        alertBox.className = "mt-4 p-4 rounded-xl border font-bold text-center transition-all bg-green-500/10 border-green-500/50 text-green-400 block";
                        alertBox.innerText = "Süper " + n + ", projenizi aldık! Yakında döneceğiz.";
                        document.getElementById("contactForm").reset();
                        
                        // Emit a tiny celebration confetti programmatically if possible later!
                    }, 1000);
                }
            }
        </div>
    );
}

