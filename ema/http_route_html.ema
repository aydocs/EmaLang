@server {
    std::http::route("/page",
        php <<<PHP
$name = $_GET_name;
if ($name == "") { $name = "guest"; }
echo "<!doctype html>";
echo "<html><head><meta charset='utf-8'><title>EMA</title></head><body>";
echo "<h1>Hello " . $name . "</h1>";
echo "<p>Served from EMA php-subset route.</p>";
echo "</body></html>";
PHP
        ,
        200,
        "text/html; charset=utf-8"
    );

    std::http::serve(8080);
}

